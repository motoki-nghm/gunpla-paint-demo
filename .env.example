# ============================================================
# gunpla-paint-demo — 環境変数サンプル
# ============================================================
# cp .env.example .env  してから API キーを記入してください。
# ⚠️  .env は絶対にコミットしないこと
# ============================================================

# Gemini API キー (必須)
# 取得: https://aistudio.google.com/apikey
# 用途: ガンプラ画像の部位別カラー分析 (gemini-2.5-flash, 無料枠あり)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 画像アップロードの最大サイズ (バイト, デフォルト: 10MB)
VITE_MAX_IMAGE_SIZE_BYTES=10485760
