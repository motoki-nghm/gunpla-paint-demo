# ============================================================
# gunpla-paint-demo — 環境変数サンプル
# ============================================================
# このファイルをコピーして .env を作成してください。
# cp .env.example .env
#
# ⚠️  .env は絶対にコミットしないこと。(.gitignore に含まれています)
# ⚠️  VITE_ prefix の変数はビルド時にバンドルに含まれます。
#     本番商用公開時は Vercel Edge Function 等でプロキシ構成にしてください。
#     (詳細: DECISIONS.md ADR-005 / SECURITY_FINDINGS.md SEC-001)
# ============================================================

# ----------------------------------------------------------------
# Gemini API キー
# ----------------------------------------------------------------
# 取得方法: https://aistudio.google.com/apikey
#
# FREE モード用 (Google AI Studio 無料枠)
# → 1日500枚まで無料、レート制限: 2 req/min
VITE_GEMINI_API_KEY_FREE=your_google_ai_studio_api_key_here

# PAID モード用 (有料 API キー)
# → $0.039/枚、レート制限緩和
VITE_GEMINI_API_KEY_PAID=your_paid_api_key_here

# ----------------------------------------------------------------
# アプリ設定
# ----------------------------------------------------------------
# デフォルトの API モード: FREE | PAID
VITE_DEFAULT_API_MODE=FREE

# 画像アップロードの最大サイズ (バイト単位, デフォルト: 10MB)
VITE_MAX_IMAGE_SIZE_BYTES=10485760
